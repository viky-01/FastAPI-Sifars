SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/knowledge_rag
CORS_ALLOW_ORIGINS=http://localhost, http://127.0.0.1

# Gemini + Pinecone
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
PINECONE_API_KEY=
PINECONE_INDEX_NAME=knowledge-rag

# JWT verification (choose provider: shared_secret | public_key | jwks | auto)
JWT_PROVIDER=auto
# Comma-separated allow-list values: HS256/384/512, RS256/384/512, ES256/384/512, PS256/384/512
JWT_ALGORITHMS=RS256

# Shared secret mode
JWT_SECRET=

# Public key mode (PEM)
JWT_PUBLIC_KEY=

# JWKS mode
# If JWT_PROVIDER=auto and JWT_ISSUER is set, JWKS URL is inferred as: <issuer>/protocol/openid-connect/certs
JWT_JWKS_URL=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_JWKS_TIMEOUT_MS=3000
JWT_JWKS_CACHE_TTL_SEC=300
JWT_JWKS_CACHE_MAX_KEYS=100

JWT_REQUIRE_EXP=true
JWT_VERIFY_NBF=true
JWT_VERIFY_IAT=false
